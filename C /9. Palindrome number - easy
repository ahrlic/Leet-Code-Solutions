9. Palindrome number - easy
#include <stdio.h>
#include <stdio.h>
#include <stdbool.h>
#include <string.h>

bool isPalindrome(int x) {
    
    int result;
    char str[20];

    snprintf(str, sizeof(str), "%d", x);

    for (int i = 0; i < strlen(str); i++) {
        for (int j = 0; j < strlen(str); j++) {

            result = strcmp(&str[i], &str[j]);
        }
        
    if (result == 1) {
        return true;
                
    } else if (result == 0){
        return false;
            
        }
    }

    return 0;
}
